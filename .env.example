# ==============================================================================
# GCP Voice AI Framework (.env.example) Configuration Template
# ==============================================================================

# GCP Project & Identity Configuration
GCP_PROJECT_ID=gen-demo-66-20250711
GCP_REGION=us-central1

# Dual Engine Provider Configuration ('vertex' or 'aistudio')
VOICE_PROVIDER_TYPE=vertex

# Gemini Live Model & Voice Specifications
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_VOICE_NAME=Puck

# Credentials (Set GEMINI_API_KEY for AI Studio or GOOGLE_APPLICATION_CREDENTIALS for ADC)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_APPLICATION_CREDENTIALS=path/to/service_account.json

# FastAPI Server Settings
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# Telemetry & Security Settings
ENABLE_CLOUD_TRACING=true
ENABLE_DLP_PII_REDACTION=false
TARGET_LATENCY_SLA_MS=800.0
